{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "agent_name": {
      "enum": [
        "claude",
        "codex",
        "hermes",
        "chatgpt",
        "local_models"
      ]
    },
    "agent_role": {
      "minLength": 1,
      "type": "string"
    },
    "artifact_sha256": {
      "additionalProperties": {
        "pattern": "^[a-f0-9]{64}$",
        "type": "string"
      },
      "type": "object"
    },
    "blockers": {
      "items": {
        "type": "string"
      },
      "maxItems": 100,
      "type": "array"
    },
    "branch": {
      "minLength": 1,
      "type": "string"
    },
    "commands_run": {
      "items": {
        "type": "string"
      },
      "maxItems": 100,
      "type": "array"
    },
    "files_touched": {
      "items": {
        "type": "string"
      },
      "maxItems": 100,
      "type": "array"
    },
    "generated_at": {
      "format": "date-time",
      "type": "string"
    },
    "next_recommended_action": {
      "minLength": 1,
      "type": "string"
    },
    "packet_id": {
      "pattern": "^[a-z0-9_]+-[0-9]{8}-[a-z0-9][a-z0-9-]{2,100}$",
      "type": "string"
    },
    "safety": {
      "additionalProperties": false,
      "properties": {
        "contains_secrets": {
          "const": false
        },
        "human_approval_required": {
          "const": true
        },
        "live_actions_executed": {
          "const": false
        }
      },
      "required": [
        "contains_secrets",
        "live_actions_executed",
        "human_approval_required"
      ],
      "type": "object"
    },
    "schema_version": {
      "const": "1.0"
    },
    "source_sha256": {
      "additionalProperties": {
        "pattern": "^[a-f0-9]{64}$",
        "type": "string"
      },
      "type": "object"
    },
    "task": {
      "minLength": 1,
      "type": "string"
    },
    "tests_failed": {
      "items": {
        "type": "string"
      },
      "maxItems": 100,
      "type": "array"
    },
    "tests_passed": {
      "items": {
        "type": "string"
      },
      "maxItems": 100,
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "packet_id",
    "agent_name",
    "agent_role",
    "branch",
    "task",
    "files_touched",
    "commands_run",
    "tests_passed",
    "tests_failed",
    "blockers",
    "next_recommended_action",
    "generated_at",
    "source_sha256",
    "artifact_sha256",
    "safety"
  ],
  "title": "Ghoti Agent Handoff Packet",
  "type": "object"
}
