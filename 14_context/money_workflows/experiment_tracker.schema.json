{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GhotiExperiment",
  "description": "Schema for a single Ghoti money experiment entry in experiment_tracker.jsonl",
  "type": "object",
  "required": [
    "experiment_id",
    "created_at",
    "workflow_type",
    "source",
    "product_idea",
    "target_customer",
    "pain_point",
    "offer",
    "status",
    "next_action",
    "approval_required"
  ],
  "properties": {
    "experiment_id": {
      "type": "string",
      "description": "Stable ID, e.g. exp_20260428_120000_a1b2c3"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO timestamp of record creation"
    },
    "workflow_type": {
      "type": "string",
      "description": "Category of experiment",
      "examples": [
        "digital_product",
        "prompt_pack",
        "video_to_business_system",
        "whop_community",
        "faceless_short_form",
        "simple_phone_game",
        "email_lead_magnet",
        "productized_service"
      ]
    },
    "source": {
      "type": "string",
      "description": "Origin of the idea (YouTube URL, transcript, user note, trend, etc.)"
    },
    "product_idea": {
      "type": "string",
      "description": "One-sentence description of what is being built or tested"
    },
    "target_customer": {
      "type": "string",
      "description": "Who the buyer, viewer, or subscriber is"
    },
    "pain_point": {
      "type": "string",
      "description": "The painful problem being solved"
    },
    "offer": {
      "type": "string",
      "description": "What is offered and how it solves the pain"
    },
    "price_test": {
      "type": ["string", "null"],
      "description": "Price range being tested, e.g. '$9–$27' or null if not priced yet"
    },
    "distribution_channels": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Planned distribution channels, e.g. ['email_list', 'tiktok', 'whop']"
    },
    "content_assets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of content or asset files related to this experiment"
    },
    "status": {
      "type": "string",
      "enum": ["idea", "selected", "asset_draft", "approval_needed", "published", "measuring", "done", "blocked", "killed"],
      "description": "Current lifecycle status"
    },
    "next_action": {
      "type": "string",
      "description": "The single most important next step"
    },
    "metrics": {
      "type": "object",
      "description": "Observed performance metrics",
      "properties": {
        "impressions": { "type": "integer" },
        "clicks": { "type": "integer" },
        "opt_ins": { "type": "integer" },
        "replies": { "type": "integer" },
        "sales": { "type": "integer" },
        "revenue_usd": { "type": "number" },
        "time_spent_hours": { "type": "number" }
      },
      "additionalProperties": false
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Operator-assessed risk level"
    },
    "approval_required": {
      "type": "boolean",
      "description": "True if any live action (posting, selling, outreach, payment, app-store) requires human approval before proceeding"
    },
    "notes": {
      "type": "string",
      "description": "Free-text notes, learnings, or links to artifacts"
    },
    "files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Repo-relative file paths of related assets"
    },
    "scoring": {
      "type": "object",
      "description": "Optional experiment priority scoring (all 10 fields required if scoring is present)",
      "properties": {
        "raw_scores": {
          "type": "object",
          "description": "Raw 1-5 scores as entered",
          "required": [
            "speed_to_ship", "pain_intensity", "buyer_access", "distribution_leverage",
            "proof_difficulty", "build_complexity", "legal_tos_risk_score",
            "monetization_clarity", "content_volume_potential", "email_list_potential"
          ],
          "properties": {
            "speed_to_ship":           { "type": "integer", "minimum": 1, "maximum": 5 },
            "pain_intensity":          { "type": "integer", "minimum": 1, "maximum": 5 },
            "buyer_access":            { "type": "integer", "minimum": 1, "maximum": 5 },
            "distribution_leverage":   { "type": "integer", "minimum": 1, "maximum": 5 },
            "proof_difficulty":        { "type": "integer", "minimum": 1, "maximum": 5 },
            "build_complexity":        { "type": "integer", "minimum": 1, "maximum": 5 },
            "legal_tos_risk_score":    { "type": "integer", "minimum": 1, "maximum": 5 },
            "monetization_clarity":    { "type": "integer", "minimum": 1, "maximum": 5 },
            "content_volume_potential":{ "type": "integer", "minimum": 1, "maximum": 5 },
            "email_list_potential":    { "type": "integer", "minimum": 1, "maximum": 5 }
          },
          "additionalProperties": false
        },
        "adjusted_scores": {
          "type": "object",
          "description": "Adjusted scores after inverting lower-is-better fields (6 - raw); range 1-5",
          "required": [
            "speed_to_ship", "pain_intensity", "buyer_access", "distribution_leverage",
            "proof_difficulty", "build_complexity", "legal_tos_risk_score",
            "monetization_clarity", "content_volume_potential", "email_list_potential"
          ],
          "properties": {
            "speed_to_ship":           { "type": "integer", "minimum": 1, "maximum": 5 },
            "pain_intensity":          { "type": "integer", "minimum": 1, "maximum": 5 },
            "buyer_access":            { "type": "integer", "minimum": 1, "maximum": 5 },
            "distribution_leverage":   { "type": "integer", "minimum": 1, "maximum": 5 },
            "proof_difficulty":        { "type": "integer", "minimum": 1, "maximum": 5 },
            "build_complexity":        { "type": "integer", "minimum": 1, "maximum": 5 },
            "legal_tos_risk_score":    { "type": "integer", "minimum": 1, "maximum": 5 },
            "monetization_clarity":    { "type": "integer", "minimum": 1, "maximum": 5 },
            "content_volume_potential":{ "type": "integer", "minimum": 1, "maximum": 5 },
            "email_list_potential":    { "type": "integer", "minimum": 1, "maximum": 5 }
          },
          "additionalProperties": false
        },
        "total_score": {
          "type": "integer",
          "description": "Sum of all adjusted scores (max 50). 40+=A, 32-39=B, 24-31=C, <24=D"
        },
        "priority_bucket": {
          "type": "string",
          "enum": ["A", "B", "C", "D"],
          "description": "A=40+, B=32-39, C=24-31, D=<24"
        }
      },
      "required": ["raw_scores", "adjusted_scores", "total_score", "priority_bucket"],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
