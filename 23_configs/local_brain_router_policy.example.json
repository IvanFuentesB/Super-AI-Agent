{
  "status_label": "example_policy",
  "routing_mode": "preview_only",
  "enabled": false,
  "autonomous_execution_enabled": false,
  "default_local_model": "gemma3:4b",
  "local_provider": "ollama",
  "local_task_classes": [
    "summarize_local_markdown",
    "classify_task_risk",
    "draft_checklist",
    "compress_context",
    "suggest_worker_card"
  ],
  "hard_task_classes_route_to": {
    "Claude Code": "hard multi-file or high-risk implementation",
    "Codex": "independent audit, docs, limited implementation",
    "ChatGPT": "strategy, architecture, planning, prompt generation"
  },
  "never_use_local_brain_for": [
    "secrets",
    "live_accounts",
    "payments",
    "legal_filings",
    "medical_decisions",
    "autonomous_external_actions",
    "unreviewed_code_execution",
    "broad_delete_or_cleanup",
    "provider_cap_bypass"
  ],
  "requires_human_approval_before": [
    "external_action",
    "docker_pull_or_run",
    "browser_click_or_type",
    "email_or_posting",
    "live_account_login",
    "money_or_legal_actions"
  ],
  "api_saving_policy": "Use Gemma/Ollama for easy local tasks to reduce paid API usage. Not cap bypass or quota evasion.",
  "notes": "This is an example policy file. enabled=false means the router will not run tasks automatically. preview_only mode allows --preview smoke runs without live routing."
}
