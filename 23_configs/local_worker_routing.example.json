{
  "_meta": {
    "version": "N+3.45A",
    "description": "Local worker routing config example. Copy to local_worker_routing.json and customize.",
    "note": "Do not add real API keys or credentials to this file. This is a schema example only.",
    "last_updated": "2026-05-05"
  },
  "python_automation_worker": {
    "enabled": true,
    "task_classes": [
      "validate_jsonl",
      "parse_file",
      "generate_report",
      "generate_markdown",
      "generate_csv",
      "queue_processing",
      "prompt_bus_status",
      "study_tracker_template",
      "course_certificate_backlog_template"
    ],
    "allowed_paths": [
      "03_scripts/",
      "05_logs/",
      "14_context/",
      "output/"
    ],
    "forbidden": [
      "external_api",
      "credentials",
      "live_accounts",
      "writes_outside_repo"
    ]
  },
  "gemma_local_worker": {
    "enabled": false,
    "note": "Set enabled=true only when Ollama is running with Gemma3:4b. Output is always draft.",
    "ollama_model": "gemma3:4b",
    "ollama_base_url": "http://localhost:11434",
    "task_classes": [
      "compress_context",
      "summarize_file",
      "score_artifact",
      "draft_content"
    ],
    "output_status": "draft",
    "promotion_required": true,
    "forbidden": [
      "canonical_writes_without_human_review",
      "external_api",
      "live_accounts"
    ]
  },
  "claude_code_impl": {
    "note": "Claude Code sessions — use for implementation, commits, reasoning, tests.",
    "prompt_path": "14_context/ghoti_current_prompt.md",
    "task_classes": [
      "implementation",
      "tests",
      "commits",
      "file_editing",
      "reasoning"
    ]
  },
  "codex_audit": {
    "note": "Codex sessions — use for audit, source-check, safety gate, spec writing.",
    "prompt_template": "14_context/prompt_bus/templates/codex_prompt_template.md",
    "outbox_path": "14_context/prompt_bus/outbox/",
    "task_classes": [
      "audit",
      "source_check",
      "safety_gate",
      "spec_writing"
    ]
  },
  "chatgpt_strategy": {
    "note": "ChatGPT sessions — use for strategy, architecture, next-milestone planning.",
    "prompt_template": "14_context/prompt_bus/templates/chatgpt_handoff_template.md",
    "task_classes": [
      "strategy",
      "architecture",
      "next_milestone_planning",
      "prompt_design"
    ]
  },
  "human_approval_required": {
    "note": "Any live/account/public/money action. STOP and ask the human first.",
    "triggers": [
      "live_account_access",
      "email_send",
      "post_public",
      "payment",
      "job_application",
      "scraping",
      "giveaway_entry",
      "credential_use",
      "course_submission"
    ]
  }
}
